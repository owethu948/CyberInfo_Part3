<Window x:Class="CyberInfo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberInfo – Cybersecurity Awareness Bot"
        Height="760" Width="1140"
        Background="#FFF0F5"
        WindowStartupLocation="CenterScreen"
        MinHeight="640" MinWidth="900">

    <Window.Resources>
        <!-- ── Colour palette ── -->
        <SolidColorBrush x:Key="AccentPink"     Color="#D63384"/>
        <SolidColorBrush x:Key="AccentLight"    Color="#FF6EB4"/>
        <SolidColorBrush x:Key="TextPrimary"    Color="#3A0A1E"/>
        <SolidColorBrush x:Key="TextMuted"      Color="#A0607A"/>
        <SolidColorBrush x:Key="BgUserBubble"   Color="#FFD6EB"/>
        <SolidColorBrush x:Key="BgBotBubble"    Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderAccent"   Color="#FFB6D9"/>
        <SolidColorBrush x:Key="SidebarBg"      Color="#FFD6E8"/>
        <SolidColorBrush x:Key="InputBg"        Color="#FFF0F5"/>
        <SolidColorBrush x:Key="CardBg"         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SuccessGreen"   Color="#2DBE6C"/>
        <SolidColorBrush x:Key="DangerRed"      Color="#E74C3C"/>

        <!-- ── Generic button base ── -->
        <Style x:Key="PinkButton" TargetType="Button">
            <Setter Property="Background"           Value="{StaticResource AccentPink}"/>
            <Setter Property="Foreground"           Value="White"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="Padding"              Value="14,8"/>
            <Setter Property="FontWeight"           Value="SemiBold"/>
            <Setter Property="FontSize"             Value="13"/>
            <Setter Property="Cursor"               Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B02070"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E0AACA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Ghost / outline button -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource AccentPink}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource AccentPink}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12,6"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFD6E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sidebar nav button -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="Foreground"               Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Padding"                  Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Cursor"                   Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFB6D9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Quiz answer option button -->
        <Style x:Key="QuizOptionButton" TargetType="Button">
            <Setter Property="Background"       Value="#FFFFFF"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderAccent}"/>
            <Setter Property="BorderThickness"  Value="1.5"/>
            <Setter Property="Padding"          Value="14,10"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin"           Value="0,4"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE4EC"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentPink}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox base -->
        <Style x:Key="ChatInput" TargetType="TextBox">
            <Setter Property="Background"       Value="White"/>
            <Setter Property="BorderBrush"      Value="{StaticResource AccentPink}"/>
            <Setter Property="BorderThickness"  Value="1.5"/>
            <Setter Property="Padding"          Value="10,8"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════
             LEFT SIDEBAR
             ══════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}" Padding="12,16">
            <DockPanel>

                <!-- Bot title -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="🛡️ CyberInfo" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentPink}"/>
                    <TextBlock Text="Cybersecurity Awareness Bot"
                               FontSize="11" Foreground="{StaticResource TextMuted}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- User badge -->
                <Border DockPanel.Dock="Top" Background="#FFE4EC" CornerRadius="8"
                        Padding="10,8" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="UserBadge" Text="Welcome!"
                                   FontWeight="Bold" FontSize="13"
                                   Foreground="{StaticResource AccentPink}"/>
                        <TextBlock x:Name="MemLastTopic" Text="Last topic: —"
                                   FontSize="11" Foreground="{StaticResource TextMuted}"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="MemInterests" Text="Interests: —"
                                   FontSize="11" Foreground="{StaticResource TextMuted}"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Separator DockPanel.Dock="Top" Margin="0,0,0,8" Background="{StaticResource BorderAccent}"/>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="NAVIGATE" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="2,0,0,6"/>
                    <Button Content="💬  Chat"          Style="{StaticResource NavButton}" Click="Nav_Chat_Click"/>
                    <Button Content="📋  Task Assistant" Style="{StaticResource NavButton}" Click="Nav_Tasks_Click"/>
                    <Button Content="🎮  Quiz Game"     Style="{StaticResource NavButton}" Click="Nav_Quiz_Click"/>
                    <Button Content="📜  Activity Log"  Style="{StaticResource NavButton}" Click="Nav_Log_Click"/>

                    <Separator Margin="0,10,0,10" Background="{StaticResource BorderAccent}"/>

                    <TextBlock Text="QUICK ACTIONS" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="2,0,0,6"/>
                    <Button Content="⚠️  Scenario"      Style="{StaticResource NavButton}" Click="Sidebar_Scenario_Click"/>
                    <Button Content="📊  Cyber Fact"    Style="{StaticResource NavButton}" Click="Sidebar_Fact_Click"/>
                    <Button Content="💡  Security Tip"  Style="{StaticResource NavButton}" Click="Sidebar_Tip_Click"/>
                </StackPanel>

                <!-- Version footer -->
                <TextBlock DockPanel.Dock="Bottom" Text="Part 3 – POE 2025"
                           FontSize="10" Foreground="{StaticResource TextMuted}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════
             RIGHT CONTENT AREA
             ══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Top bar -->
                <RowDefinition Height="*"/>     <!-- Tab content -->
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="{StaticResource AccentPink}" Padding="14,10">
                <Grid>
                    <TextBlock x:Name="TopBarTitle"
                               Text="CyberInfo  |  Chat"
                               FontSize="17" FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center"/>

                    <!-- Sentiment badge (right) -->
                    <Border x:Name="SentimentBar" Background="#FFE4EC" CornerRadius="6"
                            Padding="8,4" VerticalAlignment="Center"
                            HorizontalAlignment="Right" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SentimentLabel" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="SentimentEmoji" FontSize="14"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ─────────────────────────────────────
                 TAB PANELS (shown one at a time)
                 ───────────────────────────────────── -->
            <Grid Grid.Row="1">

                <!-- ====================================
                     PANEL 0 : CHAT
                     ==================================== -->
                <Grid x:Name="PanelChat" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>  <!-- typing indicator -->
                        <RowDefinition Height="Auto"/>  <!-- scenario quiz -->
                        <RowDefinition Height="Auto"/>  <!-- input row -->
                    </Grid.RowDefinitions>

                    <!-- Chat scroll -->
                    <ScrollViewer x:Name="ChatScroll"
                                  Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#FFF0F5"
                                  Padding="14,10">
                        <StackPanel x:Name="ChatPanel"/>
                    </ScrollViewer>

                    <!-- Typing indicator -->
                    <Border x:Name="TypingRow" Grid.Row="1"
                            Background="#FFD6E8" Padding="12,8"
                            CornerRadius="8" Margin="16,0,16,4"
                            Visibility="Collapsed">
                        <TextBlock Text="CyberInfo is typing…"
                                   FontStyle="Italic"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="13"/>
                    </Border>

                    <!-- Scenario quiz panel -->
                    <Border x:Name="ScenarioPanelBox" Grid.Row="2"
                            Background="#FFE4EC" CornerRadius="10"
                            Padding="16" Margin="14,4"
                            BorderBrush="{StaticResource AccentPink}" BorderThickness="1"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="📋 SCENARIO CHALLENGE" FontWeight="Bold"
                                       FontSize="14" Foreground="{StaticResource AccentPink}"
                                       Margin="0,0,0,6"/>
                            <TextBlock x:Name="ScenarioDesc" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
                            <StackPanel x:Name="ScenarioOptionsPanel"/>
                            <Button Content="✖ Cancel Scenario" Style="{StaticResource GhostButton}"
                                    HorizontalAlignment="Right" Margin="0,8,0,0"
                                    Click="CancelScenario_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Input area -->
                    <Border Grid.Row="3" Background="{StaticResource InputBg}" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <TextBox x:Name="InputBox"
                                         Style="{StaticResource ChatInput}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="False"
                                         KeyDown="InputBox_KeyDown"
                                         TextChanged="InputBox_TextChanged"/>
                                <TextBlock x:Name="Placeholder"
                                           Text="Type a topic, ask a question, or try 'add task to…'"
                                           IsHitTestVisible="False"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="13" Margin="13,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <Button x:Name="SendBtn" Content="SEND"
                                    Grid.Column="1" Margin="6,0"
                                    Style="{StaticResource PinkButton}"
                                    IsEnabled="False"
                                    Click="SendButton_Click"/>

                            <Button Content="✖ CLEAR"
                                    Grid.Column="2"
                                    Style="{StaticResource GhostButton}"
                                    Click="ClearInput_Click"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ====================================
                     PANEL 1 : TASK ASSISTANT
                     ==================================== -->
                <Grid x:Name="PanelTasks" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Add task form -->
                    <Border Grid.Row="0" Background="{StaticResource CardBg}"
                            BorderBrush="{StaticResource BorderAccent}" BorderThickness="0,0,0,1"
                            Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                                       Text="➕  Add Cybersecurity Task"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource AccentPink}"
                                       Margin="0,0,0,10"/>

                            <TextBox x:Name="TaskTitleBox"
                                     Grid.Row="1" Grid.Column="0"
                                     Style="{StaticResource ChatInput}"
                                     Margin="0,0,8,0"
                                     FontSize="13"
                                     Tag="Task title (e.g. Enable 2FA)"/>

                            <TextBox x:Name="TaskDescBox"
                                     Grid.Row="1" Grid.Column="1"
                                     Style="{StaticResource ChatInput}"
                                     Margin="0,0,8,0"
                                     FontSize="13"
                                     Tag="Description (optional)"/>

                            <DatePicker x:Name="TaskReminderPicker"
                                        Grid.Row="1" Grid.Column="2"
                                        Margin="0,0,8,0" VerticalAlignment="Center"
                                        FontSize="13" MinWidth="130"
                                        ToolTip="Reminder date (optional)"/>

                            <Button Content="Add Task"
                                    Grid.Row="1" Grid.Column="3"
                                    Style="{StaticResource PinkButton}"
                                    Click="AddTask_Click"/>
                        </Grid>
                    </Border>

                    <!-- Task list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="📋  Pending Tasks"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <Button Content="↻ Refresh" Style="{StaticResource GhostButton}"
                                        Margin="12,0,0,0" Padding="8,4"
                                        FontSize="12" Click="RefreshTasks_Click"/>
                                <Button Content="✔ Show Completed" Style="{StaticResource GhostButton}"
                                        Margin="8,0,0,0" Padding="8,4"
                                        FontSize="12" Click="ToggleCompleted_Click"
                                        x:Name="ToggleCompletedBtn"/>
                            </StackPanel>

                            <ListView x:Name="TaskListView"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      SelectionMode="Single">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="ID"    Width="45"
                                                        DisplayMemberBinding="{Binding Id}"/>
                                        <GridViewColumn Header="Title" Width="220"
                                                        DisplayMemberBinding="{Binding Title}"/>
                                        <GridViewColumn Header="Description" Width="200"
                                                        DisplayMemberBinding="{Binding Description}"/>
                                        <GridViewColumn Header="Created"  Width="110"
                                                        DisplayMemberBinding="{Binding Created}"/>
                                        <GridViewColumn Header="Reminder" Width="110"
                                                        DisplayMemberBinding="{Binding Reminder}"/>
                                        <GridViewColumn Header="Done" Width="60"
                                                        DisplayMemberBinding="{Binding Status}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Task action buttons -->
                    <Border Grid.Row="2" Background="{StaticResource InputBg}"
                            BorderBrush="{StaticResource BorderAccent}" BorderThickness="0,1,0,0"
                            Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="✔ Mark Complete"
                                    Style="{StaticResource PinkButton}"
                                    Margin="0,0,8,0"
                                    Click="MarkTaskComplete_Click"/>
                            <Button Content="🗑 Delete Task"
                                    Style="{StaticResource GhostButton}"
                                    Margin="0,0,8,0"
                                    Click="DeleteTask_Click"/>
                            <TextBlock x:Name="TaskStatusLabel"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ====================================
                     PANEL 2 : MINI GAME (QUIZ)
                     ==================================== -->
                <Grid x:Name="PanelQuiz" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Quiz header / score bar -->
                    <Border Grid.Row="0" Background="{StaticResource AccentPink}" Padding="16,12">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="🎮  Cybersecurity Quiz Challenge"
                                           FontSize="16" FontWeight="Bold" Foreground="White"/>
                                <TextBlock x:Name="QuizProgressLabel"
                                           Text="Press Start to begin!"
                                           FontSize="12" Foreground="#FFE4EC"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock x:Name="QuizScoreLabel"
                                           Text="Score: 0 / 0"
                                           FontSize="14" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Quiz body -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
                        <StackPanel x:Name="QuizBodyPanel">

                            <!-- Start screen -->
                            <StackPanel x:Name="QuizStartScreen" HorizontalAlignment="Center"
                                        VerticalAlignment="Center" Margin="0,40,0,0">
                                <TextBlock Text="🛡️" FontSize="64" HorizontalAlignment="Center"/>
                                <TextBlock Text="Cybersecurity Knowledge Quiz"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource AccentPink}"
                                           HorizontalAlignment="Center" Margin="0,10,0,6"/>
                                <TextBlock Text="Test yourself on phishing, passwords, malware, 2FA and more!"
                                           FontSize="13" Foreground="{StaticResource TextMuted}"
                                           HorizontalAlignment="Center" TextWrapping="Wrap"
                                           MaxWidth="420" TextAlignment="Center"/>
                                <TextBlock Text="12 questions  •  Multiple choice &amp; True/False"
                                           FontSize="12" Foreground="{StaticResource TextMuted}"
                                           HorizontalAlignment="Center" Margin="0,6,0,20"/>
                                <Button Content="▶  Start Quiz"
                                        Style="{StaticResource PinkButton}"
                                        Padding="28,12" FontSize="15"
                                        HorizontalAlignment="Center"
                                        Click="StartQuiz_Click"/>
                            </StackPanel>

                            <!-- Active question panel -->
                            <Border x:Name="QuizQuestionPanel"
                                    Background="{StaticResource CardBg}"
                                    CornerRadius="12" Padding="20"
                                    BorderBrush="{StaticResource BorderAccent}"
                                    BorderThickness="1.5"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <!-- Progress bar -->
                                    <Grid Margin="0,0,0,12">
                                        <ProgressBar x:Name="QuizProgressBar"
                                                     Height="8" Minimum="0" Maximum="12" Value="0"
                                                     Background="#FFE4EC"
                                                     Foreground="{StaticResource AccentPink}"
                                                     BorderThickness="0"/>
                                    </Grid>

                                    <TextBlock x:Name="QuizQuestionNumber"
                                               Text="Question 1 of 12"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,8"/>

                                    <TextBlock x:Name="QuizQuestionText"
                                               Text=""
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,16"/>

                                    <StackPanel x:Name="QuizOptionsPanel"/>

                                    <!-- Feedback box -->
                                    <Border x:Name="QuizFeedbackBox"
                                            CornerRadius="8" Padding="14,10"
                                            Margin="0,12,0,0" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock x:Name="QuizFeedbackText"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock x:Name="QuizExplanationText"
                                                       FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Button x:Name="QuizNextBtn"
                                            Content="Next Question ▶"
                                            Style="{StaticResource PinkButton}"
                                            HorizontalAlignment="Right"
                                            Margin="0,14,0,0"
                                            Visibility="Collapsed"
                                            Click="QuizNext_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- Results panel -->
                            <Border x:Name="QuizResultsPanel"
                                    Background="{StaticResource CardBg}"
                                    CornerRadius="12" Padding="24"
                                    BorderBrush="{StaticResource BorderAccent}"
                                    BorderThickness="1.5"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="Center"
                                    MaxWidth="520">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="QuizResultsEmoji"
                                               FontSize="56" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="QuizResultsScore"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource AccentPink}"
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,6"/>
                                    <TextBlock x:Name="QuizResultsMsg"
                                               FontSize="14"
                                               Foreground="{StaticResource TextPrimary}"
                                               HorizontalAlignment="Center"
                                               TextWrapping="Wrap" TextAlignment="Center"
                                               MaxWidth="380"/>
                                    <Button Content="🔄  Play Again"
                                            Style="{StaticResource PinkButton}"
                                            Padding="22,10" FontSize="14"
                                            HorizontalAlignment="Center"
                                            Margin="0,20,0,0"
                                            Click="StartQuiz_Click"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Quiz footer -->
                    <Border Grid.Row="2" Background="{StaticResource InputBg}"
                            BorderBrush="{StaticResource BorderAccent}" BorderThickness="0,1,0,0"
                            Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="QuizTimerLabel"
                                       Text="⏱ 0s elapsed"
                                       FontSize="12" Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center"/>
                            <Button Content="✖ Quit Quiz"
                                    Style="{StaticResource GhostButton}"
                                    Margin="12,0,0,0" Padding="8,4" FontSize="12"
                                    Click="QuitQuiz_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ====================================
                     PANEL 3 : ACTIVITY LOG
                     ==================================== -->
                <Grid x:Name="PanelLog" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Log toolbar -->
                    <Border Grid.Row="0" Background="{StaticResource CardBg}"
                            BorderBrush="{StaticResource BorderAccent}"
                            BorderThickness="0,0,0,1" Padding="16,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📜  Activity Log"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource AccentPink}"
                                       VerticalAlignment="Center"/>
                            <Button Content="↻ Refresh"  Style="{StaticResource GhostButton}"
                                    Margin="14,0,0,0" Padding="8,4" FontSize="12"
                                    Click="RefreshLog_Click"/>
                            <Button Content="💾 Export to File" Style="{StaticResource GhostButton}"
                                    Margin="8,0,0,0" Padding="8,4" FontSize="12"
                                    Click="ExportLog_Click"/>
                            <Button Content="Show More" x:Name="ShowMoreLogBtn"
                                    Style="{StaticResource GhostButton}"
                                    Margin="8,0,0,0" Padding="8,4" FontSize="12"
                                    Click="ShowMoreLog_Click"/>
                            <TextBlock x:Name="LogCountLabel"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="12" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Log list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,10">
                        <StackPanel x:Name="LogPanel"/>
                    </ScrollViewer>

                    <!-- Log footer info -->
                    <Border Grid.Row="2" Background="{StaticResource InputBg}"
                            BorderBrush="{StaticResource BorderAccent}" BorderThickness="0,1,0,0"
                            Padding="16,8">
                        <TextBlock x:Name="LogFooter"
                                   Text="Showing last 10 entries. Click 'Show More' for full history."
                                   FontSize="12" Foreground="{StaticResource TextMuted}"/>
                    </Border>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
